---
import RootLayout from '../../layouts/RootLayout.astro';
import GoogleAuthButton from '../../components/auth/GoogleAuthButton';
---

<RootLayout title="Iniciar sesión - WC 2026 Tracker">
  <div class="auth-container">
    <div class="auth-card">
      <div class="auth-header">
        <div class="auth-icon">⚽</div>
        <h1>World Cup 2026 Tracker</h1>
        <p>Inicia sesión para llevar el seguimiento de tu álbum Panini</p>
      </div>

      <GoogleAuthButton client:load />

      <p class="auth-note">
        Al continuar, aceptas que guardemos tu progreso de colección en nuestra base de datos.
      </p>
    </div>
  </div>
</RootLayout>

<style>
  .auth-container {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    padding: 1rem;
  }

  .auth-card {
    background: white;
    padding: 2.5rem 2rem;
    border-radius: 16px;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.2);
    width: 100%;
    max-width: 380px;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .auth-header {
    text-align: center;
  }

  .auth-icon {
    font-size: 3rem;
    margin-bottom: 0.75rem;
  }

  .auth-header h1 {
    font-size: 1.5rem;
    font-weight: 700;
    color: #111827;
    margin: 0 0 0.5rem;
  }

  .auth-header p {
    color: #6b7280;
    font-size: 0.9rem;
    margin: 0;
  }

  .auth-note {
    font-size: 0.75rem;
    color: #9ca3af;
    text-align: center;
    margin: 0;
    line-height: 1.5;
  }
</style>
