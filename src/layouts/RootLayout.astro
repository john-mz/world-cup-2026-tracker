  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Panini World Cup 2026 sticker album tracker" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
